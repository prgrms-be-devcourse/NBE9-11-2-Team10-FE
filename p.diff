+
+    await page.click('button[type="submit"]');
+
+    await expectErrorMessageVisible(page, '주소는 필수입니다');
+  });
+
+  // ✅ 시나리오 6: 이메일 중복 체크 - 사용 가능
+  test('이메일 중복 체크에서 사용 가능한 이메일이면 성공 메시지가 표시된다', async ({ page }) => {
