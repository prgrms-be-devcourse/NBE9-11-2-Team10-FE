+    await expect(page.locator('button:has-text("확인됨")')).toBeVisible();
+  });
+
+  // ✅ 시나리오 7: 이메일 중복 체크 - 중복된 이메일
+  test('이메일 중복 체크에서 이미 사용 중인 이메일이면 에러 메시지가 표시된다', async ({ page }) => {
