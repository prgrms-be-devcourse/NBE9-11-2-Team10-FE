+import test, { expect } from "@playwright/test";
+import { expectErrorMessageVisible } from "../utils/helper";
+
+
+test.describe('회원가입 폼 (RegisterForm)', () => {
+
+  test.beforeEach(async ({ page }) => {
+    await page.goto('/register?role=BUYER');
+  });
+
+  // ✅ 시나리오 1: 성공 케이스
